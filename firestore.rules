rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth.token.email == 'zacharyrapisss@gmail.com';
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Recipes collection
    match /recipes/{recipeId} {
      allow read: if true;
      
      // Users can create recipes (they become owner)
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      
      // Only owner or admin can update/delete recipes
      allow update, delete: if request.auth != null
        && (resource.data.authorId == request.auth.uid || isAdmin());
      
      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if request.auth != null
          && (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }
    
    // Likes collection
    match /likes/{likeId} {
      allow read: if request.auth != null;
      // Users can only create likes for themselves
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid;
      // Users can only delete their own likes (extract userId from composite key)
      allow delete: if request.auth != null 
        && (likeId.startsWith(request.auth.uid + '_') || isAdmin());
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if true;
      // Users can only create their own profile
      allow create: if request.auth != null && request.auth.uid == userId;
      // Users can only update their own profile (except role)
      allow update: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
    }
    
    // Follows collection
    match /follows/{followId} {
      allow read: if request.auth != null;
      // Users can only create follows where they are the follower
      allow create: if request.auth != null 
        && request.resource.data.followerId == request.auth.uid;
      // Users can only delete their own follows (extract followerId from composite key)
      allow delete: if request.auth != null 
        && (followId.startsWith(request.auth.uid + '_') || isAdmin());
    }
    
    // Warnings collection (admin only)
    match /warnings/{warningId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Blocked machine IDs (admin only)
    match /blockedMachineIds/{blockId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}